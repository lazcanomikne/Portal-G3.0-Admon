<template>
  <v-app id="inspire">
    <v-main>
      <v-container fluid fill-height class="loginOverlay">
        <v-layout flex align-center justify-center>
          <v-flex xs12 sm8 md6 lg4 elevation-6>
            <v-card class="premium-card">
              <v-toolbar color="transparent" flat class="pt-5">
                <v-toolbar-title class="primary--text font-weight-bold display-1 text-center" style="width:100%">
                   Portal GOVI
                </v-toolbar-title>
              </v-toolbar>
              <v-card-text class="pt-4">
                <div>
                  <v-form v-model="valid" ref="form">
                    <v-text-field label="Usuario" v-model="username" :rules="emailRules" required
                      prepend-inner-icon="people" outlined class="mb-2"></v-text-field>
                    <v-text-field label="Contraseña" v-model="password" type="password" :rules="passwordRules" required
                      prepend-inner-icon="lock" outlined @keydown.stop.enter="submit"></v-text-field>
                    <v-layout justify-space-between class="mt-4">
                      <v-btn block large @click="submit" class="btn-gradient"
                        :disabled="!valid">Entrar</v-btn>
                    </v-layout>
                  </v-form>
                </div>
              </v-card-text>
            </v-card>
          </v-flex>
        </v-layout>
        <v-overlay :value="overlay">
          <v-progress-circular indeterminate size="64"></v-progress-circular>
        </v-overlay>
      </v-container>
    </v-main>
  </v-app>
</template>

<script>
import { mapActions } from "vuex";
export default {
  name: "login",
  data () {
    return {
      valid: false,
      overlay: false,
      e1: false,
      password: "",
      passwordRules: [(v) => !!v || "Contraseña es requerida"],
      username: "",
      emailRules: [(v) => !!v || "Usuario es requerida"],
    };
  },
  methods: {
    ...mapActions("login", ["login"]),
    submit () {
      if (this.$refs.form.validate()) {
        this.overlay = true;
        this.login({ UserName: this.username, Password: this.password })
          .then((res) => {
            if (res) {
              localStorage.setItem(
                "jwt",
                escape(
                  JSON.stringify({ email: this.email, jwt: this.password })
                )
              );
              this.$store.commit("login/SET_USERNAME", this.username);
              this.$store.commit("login/SET_USERPASS", this.password);
              this.overlay = false;

              this.$router.push("/");
            }
          })
          .catch((err) => {
            this.overlay = false;
            let message = "Error desconocido (500)";
            try {
              if (err && err.data) {
                if (err.data.error && typeof err.data.error === 'string') {
                  message = `Error: ${err.data.error}`;
                } 
                else if (err.data.error && err.data.error.message) {
                  message = err.data.error.message.value || err.data.error.message;
                }
                else if (typeof err.data === 'string') {
                   message = err.data.length > 200 ? err.data.substring(0, 200) + "..." : err.data;
                }
                else {
                  message = "Respuesta del servidor: " + JSON.stringify(err.data).substring(0, 500);
                }
              }
            } catch (e) {
              message = "Error al procesar respuesta: " + e.message;
            }
            alert(message);
          });
      }
    },
    clear () {
      this.$refs.form.reset();
    },
  },
};
</script>

<style scoped>
.loginOverlay {
  background: #eeeeee;
}
</style>
